{
  "manifest_version": 3,
  "name": "Atomic Web Clipper",
  "version": "1.0.0",
  "description": "Capture web content to Atomic note-taking app",

  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "http://localhost:44380/*",
    "http://127.0.0.1:44380/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/readability.min.js",
        "lib/turndown.min.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
